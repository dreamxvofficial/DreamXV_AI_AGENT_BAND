{
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "script.js",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/auth/(.*)", "dest": "api/auth.py" },
    { "src": "/api/generate-project", "dest": "api/generate-project.py" },
    { "src": "/api/agents", "dest": "api/agents.py" },
    { "src": "/api/agent-status", "dest": "api/agents.py" },
    { "src": "/api/health", "dest": "api/health.py" },
    { "src": "/api/image", "dest": "api/image.py" },
    { "src": "/api/projects", "dest": "api/projects.py" },
    { "src": "/api/atlas", "dest": "api/atlas.py" },
    { "src": "/atlas", "dest": "api/atlas.py" },
    { "src": "/videos/(.*)", "dest": "public/videos/$1" },
    { "src": "/(.*)", "dest": "$1" }
  ]
}
