{
  "functions": {
    "api/*.py": {
      "maxDuration": 120
    }
  },
  "rewrites": [
    { "source": "/api/auth/:path*", "destination": "/api/auth.py" },
    { "source": "/api/generate-project", "destination": "/api/generate-project.py" },
    { "source": "/api/agents", "destination": "/api/agents.py" },
    { "source": "/api/agent-status", "destination": "/api/agents.py" },
    { "source": "/api/health", "destination": "/api/health.py" },
    { "source": "/api/image", "destination": "/api/image.py" },
    { "source": "/api/projects/regenerate-image", "destination": "/api/projects.py" },
    { "source": "/api/projects", "destination": "/api/projects.py" },
    { "source": "/api/config/:path*", "destination": "/api/config.py" },
    { "source": "/api/atlas/:path*", "destination": "/api/atlas.py" },
    { "source": "/atlas", "destination": "/api/atlas.py" },
    { "source": "/videos/:path*", "destination": "/public/videos/:path*" }
  ]
}
